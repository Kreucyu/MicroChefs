{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "📊 Visão Geral das Filas",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Mensagens Prontas (Ready)",
      "description": "Mensagens na fila aguardando consumo. Valor alto indica que os consumers não estão dando conta.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Mensagens",
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rabbitmq_queue_messages_ready{queue=\"cozinha-queue\"}",
          "legendFormat": "cozinha-queue (ready)",
          "refId": "A"
        },
        {
          "expr": "rabbitmq_queue_messages_ready{queue=\"pedido-queue\"}",
          "legendFormat": "pedido-queue (ready)",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "Mensagens Não Confirmadas (Unacked)",
      "description": "Mensagens entregues aos consumers mas ainda não confirmadas (ACK). Valor alto pode indicar processamento lento.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "Mensagens",
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rabbitmq_queue_messages_unacknowledged{queue=\"cozinha-queue\"}",
          "legendFormat": "cozinha-queue (unacked)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Consumidores Ativos por Fila",
      "description": "Número de consumidores conectados. Em escala manual, este valor deve refletir a quantidade de containers da cozinha em execução.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "Consumers",
            "drawStyle": "bars",
            "fillOpacity": 50,
            "gradientMode": "hue",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "none" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rabbitmq_queue_consumers{queue=\"cozinha-queue\"}",
          "legendFormat": "cozinha-queue consumers",
          "refId": "A"
        },
        {
          "expr": "rabbitmq_queue_consumers{queue=\"pedido-queue\"}",
          "legendFormat": "pedido-queue consumers",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "Total de Mensagens por Fila",
      "description": "Ready + Unacked. Visão geral do backlog.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background_gradient",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "expr": "rabbitmq_queue_messages_total{queue=\"cozinha-queue\"}",
          "legendFormat": "cozinha-queue",
          "refId": "A"
        },
        {
          "expr": "rabbitmq_queue_messages_total{queue=\"pedido-queue\"}",
          "legendFormat": "pedido-queue",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "title": "⚙️ Performance da Aplicação",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false
    },
    {
      "id": 7,
      "title": "Latência de Processamento — Cozinha (p50 / p95 / p99)",
      "description": "Distribuição da latência de processamento de pedidos pelo serviço Cozinha (Micrometer Timer).",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "Latência",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(cozinha_pedido_processamento_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(cozinha_pedido_processamento_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(cozinha_pedido_processamento_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 8,
      "title": "Taxa de Processamento (pedidos/min)",
      "description": "Quantos pedidos por minuto estão sendo processados pelo serviço Cozinha.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "pedidos/min",
            "drawStyle": "line",
            "fillOpacity": 25,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "opm"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(cozinha_pedido_processamento_seconds_count[5m])) * 60",
          "legendFormat": "pedidos/min",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "JVM Memory (Cozinha)",
      "description": "Uso de memória da JVM — Heap e Non-Heap.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "Memória",
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{job=\"cozinha-service\", area=\"heap\"}) by (job)",
          "legendFormat": "Heap Used",
          "refId": "A"
        },
        {
          "expr": "sum(jvm_memory_committed_bytes{job=\"cozinha-service\", area=\"heap\"}) by (job)",
          "legendFormat": "Heap Committed",
          "refId": "B"
        },
        {
          "expr": "sum(jvm_memory_max_bytes{job=\"cozinha-service\", area=\"heap\"}) by (job)",
          "legendFormat": "Heap Max",
          "refId": "C"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["microchefs", "rabbitmq", "cozinha", "docker-compose"],
